<% if(locals.therapists) { %>
<div
	id="therapists-table"
	class="table"
>
	<div class="table-head">
		<div class="th">Calendar Colour</div>
		<div class="th">Name</div>
		<div class="th">&nbsp;</div>
	</div>
	<!-- End Table Head-->

	<div class="table-body">
		<% for(therapist of therapists) { %>
		<div class="table-row">
			<div
				class="table-cell"
				style="border-left: 4px solid <%= therapist.t_colour %>"
			>
				<div
					class="colour-circle"
					style="background-color: <%= therapist.t_colour %>"
				>
					&nbsp;
				</div>
			</div>
			<div class="table-cell">
				<%= therapist.t_first_name %> <%= therapist.t_surname %>
			</div>
			<div class="table-cell">
				<a
					href="/therapist/<%= therapist.t_ID %>"
					title="view therapist"
					><i class="bi bi-eye"></i
				></a>
			</div>
		</div>
		<% } %>
	</div>
	<!-- End table body-->
</div>
<!-- End Table-->
<% } %>
