<% if(locals.clients) { %>
<div
	id="clients-table"
	class="table"
>
	<div class="table-head">
		<div class="th">ID</div>
		<div class="th">Name</div>
	</div>
	<!-- End Table Head-->

	<div class="table-body">
		<% for(client of clients) { console.log("client", client);%>

		<div class="table-row">
			<div class="table-cell"><%= client.c_ID %></div>
			<div class="table-cell">
				<%= client.c_first_name %> <%= client.c_surname %>
			</div>
		</div>

		<% } %>
	</div>
	<!-- End table body-->
</div>
<!-- End Table-->

<% } %>
