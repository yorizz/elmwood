<% if(locals.clients) { %> 
	<div
		id="clients-table"
		class="table table-responsive w-100 d-block d-md-table"
	>
		<div class="table-head">
			<div class="th">Name</div>
			<div class="th">Phone</div>
			<div class="th">Email</div>
			<div class="th">Waiting Since</div>
			<div class="th">View</div>
		</div>
		<!-- End Table Head-->

		<div class="table-body">
			<% for(client of clients) { console.log("client", client);%>

			<div class="table-row">
				<div class="table-cell">
					<%= dataDecrypt(client.c_first_name) %> <%= dataDecrypt(client.c_surname) %>
				</div>
				<div class="table-cell">
					<%= formatPhoneNumber(dataDecrypt(client.c_phone)) %>
				</div>
				<div class="table-cell">
					<a href="mailto:<%= dataDecrypt(client.c_email) %>"><%= dataDecrypt(client.c_email) %></a>
				</div>
				<div class="table-cell">
                    <%= formatDate(client.c_enquiry_date) %>
                </div>
				<div class="table-cell">
					<a
						href="/client/<%= client.c_ID %>"
						title="view client"
						><i class="bi bi-eye"></i
					></a>
				</div>
			</div>

			<% } %>
		</div>
		<!-- End table body-->
	</div>
	<!-- End Table-->

	<% } %>
</p.length;>
