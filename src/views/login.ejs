<h1>Login</h1>

<% if(messages.error) { %> <%= messages.error %> <% } %>

<form
	action="login"
	method="post"
>
	<label for="username">Username</label>
	<input
		type="text"
		name="username"
		id="username"
		placeholder="Username"
		required
	/>
	<label for="password">Password</label>
	<input
		type="password"
		name="password"
		id="password"
		placeholder="Password"
		required
	/>
	<button type="submit">Login</button>
</form>

